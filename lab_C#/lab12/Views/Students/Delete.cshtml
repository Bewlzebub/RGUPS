@model lab10_ASP.Tables.Студенты

@{
    ViewData["Title"] = "Удаление студента";
}

<h1>🗑️ Удаление студента</h1>
<div class="alert alert-danger">
    <strong>Внимание!</strong> Вы действительно хотите удалить этого студента?
</div>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Код студента</dt>
            <dd class="col-sm-9">@Model.КодСтудента</dd>

            <dt class="col-sm-3">Фамилия</dt>
            <dd class="col-sm-9">@Model.Фамилия</dd>

            <dt class="col-sm-3">Имя</dt>
            <dd class="col-sm-9">@Model.Имя</dd>

            <dt class="col-sm-3">Отчество</dt>
            <dd class="col-sm-9">@Model.Отчество</dd>

            <dt class="col-sm-3">Кафедра</dt>
            <dd class="col-sm-9">@(Model.КафедраNavigation?.Название ?? "—")</dd>

            <dt class="col-sm-3">Год рождения</dt>
            <dd class="col-sm-9">@Model.ГодРождения</dd>

            <dt class="col-sm-3">Пол</dt>
            <dd class="col-sm-9">@Model.Пол</dd>

            <dt class="col-sm-3">Город</dt>
            <dd class="col-sm-9">@Model.Город</dd>

            <dt class="col-sm-3">Телефон</dt>
            <dd class="col-sm-9">@Model.Телефон</dd>
        </dl>

        <form asp-action="Delete">
            <input type="hidden" asp-for="КодСтудента" />
            <button type="submit" class="btn btn-danger">🗑️ Удалить</button>
            <a asp-action="Index" class="btn btn-secondary">↩️ Отмена</a>
        </form>
    </div>
</div>