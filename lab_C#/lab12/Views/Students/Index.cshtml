@model IEnumerable<lab10_ASP.Tables.Студенты>

@{
    ViewData["Title"] = "Студенты";
}

<!-- Карточка с данными из конфигурации -->
<div class="card mb-4 bg-light">
    <div class="card-body">
        <h5 class="card-title">Информация из конфигурации (appsettings.json)</h5>
        <div class="row">
            <div class="col-md-6">
                <strong>ФИО:</strong> @ViewBag.MyName
            </div>
            <div class="col-md-6">
                <strong>Группа:</strong> @ViewBag.MyGroup
            </div>
            <div class="col-md-6">
                <strong>Университет:</strong> @ViewBag.MyUniversity
            </div>
            <div class="col-md-6">
                <strong>Факультет:</strong> @ViewBag.MyFaculty
            </div>
        </div>
    </div>
</div>

<h1 class="mb-4">📚 Управление студентами</h1>

<!-- Панель поиска и фильтрации -->
<div class="row mb-4">
    <div class="col-md-5">
        <form asp-action="Index" method="get" class="input-group">
            <input type="text" name="searchString" value="@ViewData["CurrentFilter"]"
                   class="form-control" placeholder="🔍 Поиск по фамилии, имени..." />
            <button type="submit" class="btn btn-primary">Поиск</button>
            <a asp-action="Index" class="btn btn-secondary">Сброс</a>
        </form>
    </div>
    <div class="col-md-4">
        <form asp-action="Index" method="get">
            <select name="departmentFilter" class="form-select" onchange="this.form.submit()">
                <option value="">📁 Все кафедры</option>
                @if (ViewBag.Departments != null)
                {
                    foreach (var dept in ViewBag.Departments)
                    {
                        if (ViewData["CurrentDepartmentFilter"] != null && (int)ViewData["CurrentDepartmentFilter"] == dept.КодКафедры)
                        {
                            <option value="@dept.КодКафедры" selected>🏛️ @dept.Название</option>
                        }
                        else
                        {
                            <option value="@dept.КодКафедры">🏛️ @dept.Название</option>
                        }
                    }
                }
            </select>
        </form>
    </div>
    <div class="col-md-3 text-end">
        <a asp-action="Create" class="btn btn-success">➕ Добавить студента</a>
    </div>
</div>

<!-- Панель сортировки -->
<div class="row mb-3">
    <div class="col-md-12">
        <div class="btn-group" role="group">
            <a asp-action="Index" asp-route-sortOrder="@ViewData["NameSortParm"]"
                   asp-route-searchString="@ViewData["CurrentFilter"]"
                   asp-route-departmentFilter="@ViewData["CurrentDepartmentFilter"]"
                   class="btn btn-outline-secondary">
                📝 Сортировать по фамилии
            </a>
            <a asp-action="Index" asp-route-sortOrder="@ViewData["BirthSortParm"]"
                   asp-route-searchString="@ViewData["CurrentFilter"]"
                   asp-route-departmentFilter="@ViewData["CurrentDepartmentFilter"]"
                   class="btn btn-outline-secondary">
                🎂 Сортировать по году рождения
            </a>
        </div>
    </div>
</div>

<!-- Таблица студентов -->
<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Код</th>
                <th>Фамилия</th>
                <th>Имя</th>
                <th>Отчество</th>
                <th>Кафедра</th>
                <th>Год рождения</th>
                <th>Пол</th>
                <th>Город</th>
                <th>Телефон</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    // Подсветка найденных строк
                    string highlightClass = "";
                    if (!string.IsNullOrEmpty(ViewData["CurrentFilter"] as string))
                    {
                        string searchTerm = ViewData["CurrentFilter"].ToString().ToLower();
                        if ((item.Фамилия != null && item.Фамилия.ToLower().Contains(searchTerm)) ||
                            (item.Имя != null && item.Имя.ToLower().Contains(searchTerm)))
                        {
                            highlightClass = "table-warning";
                        }
                    }
                    
                    <tr class="@highlightClass">
                        <td>@item.КодСтудента</td>
                        <td>@item.Фамилия</td>
                        <td>@item.Имя</td>
                        <td>@item.Отчество</td>
                        <td>@(item.КафедраNavigation?.Название ?? "—")</td>
                        <td>@item.ГодРождения</td>
                        <td>@item.Пол</td>
                        <td>@item.Город</td>
                        <td>@item.Телефон</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.КодСтудента" class="btn btn-sm btn-primary">✏️</a>
                            <a asp-action="Details" asp-route-id="@item.КодСтудента" class="btn btn-sm btn-info">📋</a>
                            <a asp-action="Delete" asp-route-id="@item.КодСтудента" class="btn btn-sm btn-danger">🗑️</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="10" class="text-center text-muted">📭 Нет данных для отображения</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="mt-3 text-muted">
    Всего студентов: @(Model?.Count() ?? 0)
</div>